# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "ccgram")
TMUX_SESSION_NAME=ccgram

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Multi-instance: Telegram group chat ID this instance owns (optional)
# When set, this instance only processes updates from this group.
# Get the ID via @userinfobot or @RawDataBot in your group.
# CCGRAM_GROUP_ID=-1001234567890

# Per-provider launch command overrides (optional)
# CCGRAM_CLAUDE_COMMAND=my-claude-wrapper (defaults to "claude")
# CCGRAM_CODEX_COMMAND=my-codex-wrapper (defaults to "codex")
# CCGRAM_GEMINI_COMMAND=my-gemini-wrapper (defaults to "gemini")
#
# Claude config directory (optional, defaults to ~/.claude)
# For Claude wrappers (ce, cc-mirror, zai) that use a different config location.
# Affects hook install, command discovery, and session monitoring.
# CLAUDE_CONFIG_DIR=~/.claude-custom

# Default provider for new topics (optional, defaults to "claude")
# Options: claude, codex, gemini, pi, shell
# CCGRAM_PROVIDER=claude

# Show hidden (dot) directories in the directory browser (optional, defaults to false)
# CCGRAM_SHOW_HIDDEN_DIRS=false

# Ack reaction emoji for forwarded messages (optional, empty = disabled)
# CCGRAM_ACK_REACTION=

# Tool-call visibility in transcripts (optional, defaults to true = hidden)
# CCGRAM_HIDE_TOOL_CALLS=true

# Ephemeral tools mode (optional, defaults to false)
# CCGRAM_EPHEMERAL_TOOLS=false

# Status emoji mode: "system" (green=working) or "user" (green=ready) (optional)
# CCGRAM_STATUS_MODE=system

# Status polling interval in seconds (optional, defaults to 1.0)
# CCGRAM_STATUS_POLL_INTERVAL=1.0

# Pane lifecycle notifications (optional, defaults to false)
# CCGRAM_PANE_LIFECYCLE_NOTIFY=false

# --- Toolbar ----------------------------------------------------------
# Path to custom toolbar.toml (optional)
# CCGRAM_TOOLBAR_CONFIG=~/.ccgram/toolbar.toml

# --- LLM (shell command generation + completion summaries) -------------
# Leave CCGRAM_LLM_PROVIDER empty to disable (shell forwards raw, no summaries)
# CCGRAM_LLM_PROVIDER=openai
# CCGRAM_LLM_API_KEY=sk-...
# CCGRAM_LLM_BASE_URL=
# CCGRAM_LLM_MODEL=gpt-4o-mini
# CCGRAM_LLM_TEMPERATURE=0.1

# --- Mini App Dashboard (optional) ------------------------------------
# Requires externally-reachable HTTPS endpoint (TLS termination + reverse proxy)
# CCGRAM_MINIAPP_BASE_URL=https://example.com
# CCGRAM_MINIAPP_HOST=127.0.0.1

# --- Voice message transcription (Whisper API) ----------------------------
# Enable by setting CCGRAM_WHISPER_PROVIDER to "openai" or "groq".
# Leave empty (default) to disable.
#
# Option A: Groq (recommended)
# CCGRAM_WHISPER_PROVIDER=groq
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
#
# Option B: OpenAI
# CCGRAM_WHISPER_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
#
# Option C: Any OpenAI-compatible endpoint
# CCGRAM_WHISPER_PROVIDER=openai
# CCGRAM_WHISPER_API_KEY=your_key
# CCGRAM_WHISPER_BASE_URL=http://localhost:8000/v1
# CCGRAM_WHISPER_MODEL=whisper-1
#
# Optional tweaks (apply to all providers):
# CCGRAM_WHISPER_MODEL=whisper-large-v3-turbo
# CCGRAM_WHISPER_LANGUAGE=en

# --- Voice replies (TTS) --------------------------------------------------
# Enable by setting CCGRAM_TTS_PROVIDER to "edge" or "openai".
# Leave empty (default) to disable. Requires: pip install ccgram[tts]
#
# CCGRAM_TTS_PROVIDER=edge
# CCGRAM_TTS_VOICE=en-US-EmmaMultilingualNeural
# CCGRAM_TTS_API_KEY=
# CCGRAM_TTS_MODEL=

# --- Shell provider prompt mode ---------------------------------------
# CCGRAM_PROMPT_MODE=wrap
# CCGRAM_PROMPT_MARKER=ccgram
